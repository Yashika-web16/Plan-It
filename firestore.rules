rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.get('email', '') == "seema.nagdev16@gmail.com") ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    // Public Collections - allow read to everyone
    match /events/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /venues/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /hotels/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Private Collections
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        request.auth.uid in resource.data.get('participantIds', []) ||
        // Allow reading for RSVP if the user has the link (we can't easily verify the link in rules, 
        // but we can allow read if they are in the guest list by email if we had that info)
        true 
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || // Organizer can do anything
        // Guests can update their RSVP status and add themselves to participantIds
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['details', 'participantIds']))
      );
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
    }

    match /scavenger_submissions/{submissionId} {
      allow read: if true; // Allow everyone to see the leaderboard/submissions for an event
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.status == 'pending';
      allow update: if isAdmin() || (isAuthenticated() && get(/databases/$(database)/documents/bookings/$(resource.data.eventId)).data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }
    
    // No catch-all needed if everything is explicitly defined
  }
}
